<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConferencePlayer.ViewModels"
        x:Class="ConferencePlayer.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Project Vela - Settings"
        Width="800" Height="700"
        FontSize="16"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*, Auto" Margin="0,0,0,10">

    <TabControl Grid.Row="0">
      <!-- GENERAL TAB -->
      <TabItem Header="General">
        <ScrollViewer>
            <StackPanel Margin="16" Spacing="12">
              <TextBlock Text="Output" FontWeight="Bold" FontSize="24"/>
              <StackPanel Spacing="6">
                <TextBlock Text="Preferred output screen"/>
                <ComboBox ItemsSource="{Binding AvailableScreens}"
                          SelectedItem="{Binding PreferredOutputScreenName, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>
              </StackPanel>

              <Separator/>

              <TextBlock Text="Panic Blackout" FontWeight="Bold" FontSize="24"/>
              <CheckBox Content="Mute audio during panic (default ON)"
                        IsChecked="{Binding PanicMutesAudio, Mode=TwoWay}"/>
              <CheckBox Content="Restore previous mute state when leaving panic"
                        IsChecked="{Binding RestoreAudioAfterPanic, Mode=TwoWay}"/>
              <CheckBox Content="Resume playback automatically when leaving panic (default OFF)"
                        IsChecked="{Binding ResumePlaybackAfterPanic, Mode=TwoWay}"/>

              <Separator/>

              <TextBlock Text="Playlist" FontWeight="Bold" FontSize="24"/>
              <CheckBox Content="Auto-advance to next item when media ends"
                        IsChecked="{Binding AutoAdvancePlaylist, Mode=TwoWay}"/>
              <CheckBox Content="Loop playlist when reaching the end (requires auto-advance)"
                        IsChecked="{Binding LoopPlaylist, Mode=TwoWay}"/>
              <CheckBox Content="Persist playlist between launches (default ON)"
                        IsChecked="{Binding PersistPlaylist, Mode=TwoWay}"/>
              <CheckBox Content="Enable Preview window (preload next item paused)"
                        IsChecked="{Binding EnablePreviewWindow, Mode=TwoWay}"/>
              <CheckBox Content="Preview cues selected item (instead of next)"
                        IsChecked="{Binding PreviewCuesSelectedItem, Mode=TwoWay}"/>
              <CheckBox Content="Enable Preview audio monitoring (default OFF)"
                        IsChecked="{Binding PreviewAudioEnabled, Mode=TwoWay}"/>

              <Separator/>

              <TextBlock Text="Folder Watch" FontWeight="Bold" FontSize="24"/>
              <CheckBox Content="Enable folder watch"
                        IsChecked="{Binding WatchFolderEnabled, Mode=TwoWay}"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="520"
                         Watermark="Folder path (local)"
                         Text="{Binding WatchedFolderPath, Mode=TwoWay}"/>
                <Button Content="Browse" Command="{Binding BrowseWatchFolderCommand}" Height="40"/>
              </StackPanel>
              <CheckBox Content="Include subfolders"
                        IsChecked="{Binding IncludeSubfolders, Mode=TwoWay}"/>

              <Separator/>

              <TextBlock Text="Logging" FontWeight="Bold" FontSize="24"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBox Width="520"
                         Watermark="Logs folder path (requires restart)"
                         Text="{Binding LogsFolderPath, Mode=TwoWay}"/>
                <Button Content="Browse" Command="{Binding BrowseLogsFolderCommand}" Height="40"/>
              </StackPanel>
              <TextBlock Text="{Binding LogsRestartMessage}"
                         Foreground="Orange" FontWeight="Bold"
                         IsVisible="{Binding !!LogsRestartMessage}"/>
            </StackPanel>
        </ScrollViewer>
      </TabItem>

      <!-- SHORTCUTS TAB -->
      <TabItem Header="Shortcuts">
        <ScrollViewer>
            <StackPanel Margin="16" Spacing="10">
                <TextBlock Text="Keyboard Shortcuts (Key Gestures)" FontWeight="Bold" FontSize="18" Margin="0,0,0,10"/>
                <TextBlock Text="Enter gestures like 'Ctrl+O', 'Space', 'F12'." Opacity="0.7" FontStyle="Italic"/>

                <Grid ColumnDefinitions="250, *" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,10,0,0">
                    <Grid.Styles>
                        <Style Selector="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="0,5"/>
                        </Style>
                        <Style Selector="TextBox">
                            <Setter Property="Margin" Value="0,2"/>
                        </Style>
                    </Grid.Styles>

                    <TextBlock Grid.Row="0" Text="Play / Pause"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding HotKey_PlayPause}"/>

                    <TextBlock Grid.Row="1" Text="Stop"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding HotKey_Stop}"/>

                    <TextBlock Grid.Row="2" Text="Play Next (Immediate)"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HotKey_PlayNext}"/>

                    <TextBlock Grid.Row="3" Text="Play Prev (Immediate)"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding HotKey_PlayPrev}"/>

                    <TextBlock Grid.Row="4" Text="Frame Step"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding HotKey_FrameStep}"/>

                    <TextBlock Grid.Row="5" Text="Select Next (Cue)"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding HotKey_SelectNext}"/>

                    <TextBlock Grid.Row="6" Text="Select Prev (Cue)"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding HotKey_SelectPrev}"/>

                    <TextBlock Grid.Row="7" Text="Seek Forward (+10s)"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding HotKey_SeekForward}"/>

                    <TextBlock Grid.Row="8" Text="Seek Back (-10s)"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding HotKey_SeekBack}"/>

                    <TextBlock Grid.Row="9" Text="Speed Up"/>
                    <TextBox Grid.Row="9" Grid.Column="1" Text="{Binding HotKey_IncreaseSpeed}"/>

                    <TextBlock Grid.Row="10" Text="Speed Down"/>
                    <TextBox Grid.Row="10" Grid.Column="1" Text="{Binding HotKey_DecreaseSpeed}"/>

                    <TextBlock Grid.Row="11" Text="Panic Blackout"/>
                    <TextBox Grid.Row="11" Grid.Column="1" Text="{Binding HotKey_Panic}"/>

                    <TextBlock Grid.Row="12" Text="Add Files"/>
                    <TextBox Grid.Row="12" Grid.Column="1" Text="{Binding HotKey_AddFiles}"/>

                    <TextBlock Grid.Row="13" Text="Add Folder"/>
                    <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding HotKey_AddFolder}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>

    <!-- FOOTER (Buttons) -->
    <StackPanel Grid.Row="1" Margin="16,0" Spacing="8">
        <TextBlock Text="{Binding ValidationMessage}" Foreground="Red" HorizontalAlignment="Center" FontWeight="Bold"/>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Content="Cancel" Command="{Binding CancelCommand}" Height="40" Width="100"/>
            <Button Content="Save" Command="{Binding SaveCommand}" Height="40" Width="100"/>
        </StackPanel>

        <TextBlock Text="{Binding AppVersion}"
                   HorizontalAlignment="Center"
                   Opacity="0.4"
                   FontSize="12"
                   Margin="0,5"/>
    </StackPanel>

  </Grid>
</Window>
