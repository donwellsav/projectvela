<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConferencePlayer.ViewModels"
        xmlns:core="using:ConferencePlayer.Core"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="ConferencePlayer.Views.ControlWindow"
        x:DataType="vm:ControlViewModel"
        Title="{Binding WindowTitle}"
        Width="980" Height="680"
        WindowStartupLocation="CenterScreen">

  <Window.KeyBindings>
    <KeyBinding Gesture="Space" Command="{Binding TogglePlayPauseCommand}"/>
    <KeyBinding Gesture="Enter" Command="{Binding PlaySelectedCommand}"/>
    <KeyBinding Gesture="Delete" Command="{Binding RemoveSelectedCommand}"/>
    <KeyBinding Gesture="F" Command="{Binding FrameStepCommand}"/>
    <KeyBinding Gesture="F12" Command="{Binding PanicCommand}"/>

    <KeyBinding Gesture="Ctrl+O" Command="{Binding AddFilesCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding AddFolderCommand}"/>

    <KeyBinding Gesture="Ctrl+Left" Command="{Binding PrevCommand}"/>
    <KeyBinding Gesture="Ctrl+Right" Command="{Binding NextCommand}"/>
  </Window.KeyBindings>

  <DockPanel>
    <!-- Top toolbar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8">
      <Button Content="Add Files" Command="{Binding AddFilesCommand}"/>
      <Button Content="Add Folder" Command="{Binding AddFolderCommand}"/>
      <Button Content="Settings" Command="{Binding OpenSettingsCommand}"/>
      <Button Content="Open Logs Folder" Command="{Binding OpenLogsFolderCommand}"/>
      <TextBlock Text="{Binding StatusText}" Margin="12,0,0,0" VerticalAlignment="Center"/>
    </StackPanel>

    <!-- Main content -->
    <Grid Margin="8" RowDefinitions="*,Auto" ColumnDefinitions="*,260">

      <Border Grid.Row="0" Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="6">
        <ListBox Name="PlaylistList"
                 ItemsSource="{Binding Playlist}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 DragDrop.AllowDrop="True"
                 DragDrop.DragOver="Playlist_DragOver"
                 DragDrop.Drop="Playlist_Drop">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="core:PlaylistItem">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Border>

      <Border Grid.Row="0" Grid.Column="1" BorderBrush="#444" BorderThickness="1" CornerRadius="6" Padding="10" Margin="10,0,0,0">
        <StackPanel Spacing="8">
          <TextBlock Text="Playback" FontWeight="Bold" FontSize="16"/>

          <Button Content="Play Selected (Enter)" Command="{Binding PlaySelectedCommand}"/>
          <Button Content="Play/Pause (Space)" Command="{Binding TogglePlayPauseCommand}"/>
          <Button Content="Stop" Command="{Binding StopCommand}"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Content="Prev" Command="{Binding PrevCommand}" Width="110"/>
            <Button Content="Next" Command="{Binding NextCommand}" Width="110"/>
          </StackPanel>

          <Button Content="Cue Preview" Command="{Binding CueNextPreviewCommand}"/>

          <Border Background="Black" CornerRadius="4" Height="150" Margin="0,4">
            <vlc:VideoView Name="PreviewVideoView" />
          </Border>

          <TextBlock Text="{Binding PreviewStatusText}" Opacity="0.75" TextWrapping="Wrap"/>

          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Speed" VerticalAlignment="Center"/>
            <ComboBox Width="160"
                      ItemsSource="{Binding AvailableSpeeds}"
                      SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}"/>
          </StackPanel>

          <Button Content="Frame Step (F)" Command="{Binding FrameStepCommand}"/>

          <Border Background="#2A0000" CornerRadius="6" Padding="10" Margin="0,8,0,0">
            <StackPanel Spacing="6">
              <TextBlock Text="PANIC" FontWeight="Bold" FontSize="16"/>
              <Button Content="PANIC Blackout (F12)" Command="{Binding PanicCommand}"/>
              <TextBlock Text="Black output + (optional) mute audio" Opacity="0.8"/>
            </StackPanel>
          </Border>

          <Separator/>

          <Button Content="Remove Selected (Del)" Command="{Binding RemoveSelectedCommand}"/>
          <Button Content="Clear Playlist" Command="{Binding ClearPlaylistCommand}"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#222" CornerRadius="6" Padding="10" Margin="0,10,0,0">
        <TextBlock Text="{Binding StatusText}" />
      </Border>

    </Grid>
  </DockPanel>
</Window>
