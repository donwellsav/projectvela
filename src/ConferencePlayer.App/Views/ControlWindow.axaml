<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConferencePlayer.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="ConferencePlayer.Views.ControlWindow"
        x:DataType="vm:ControlViewModel"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        FontSize="16"
        WindowStartupLocation="CenterScreen">

  <Window.KeyBindings>
    <KeyBinding Gesture="Space" Command="{Binding TogglePlayPauseCommand}"/>
    <KeyBinding Gesture="Enter" Command="{Binding PlaySelectedCommand}"/>
    <KeyBinding Gesture="Delete" Command="{Binding RemoveSelectedCommand}"/>
    <KeyBinding Gesture="F" Command="{Binding FrameStepCommand}"/>
    <KeyBinding Gesture="F12" Command="{Binding PanicCommand}"/>
    <KeyBinding Gesture="S" Command="{Binding StopCommand}"/>

    <KeyBinding Gesture="Ctrl+O" Command="{Binding AddFilesCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding AddFolderCommand}"/>

    <KeyBinding Gesture="Ctrl+Left" Command="{Binding SelectPrevCommand}"/>
    <KeyBinding Gesture="Ctrl+Right" Command="{Binding SelectNextCommand}"/>
    <KeyBinding Gesture="Shift+Left" Command="{Binding SeekBackCommand}"/>
    <KeyBinding Gesture="Shift+Right" Command="{Binding SeekForwardCommand}"/>
    <KeyBinding Gesture="OemOpenBrackets" Command="{Binding DecreaseSpeedCommand}"/>
    <KeyBinding Gesture="OemCloseBrackets" Command="{Binding IncreaseSpeedCommand}"/>
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- 1. Top Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="Add _Files..." Command="{Binding AddFilesCommand}" InputGesture="Ctrl+O"/>
        <MenuItem Header="Add F_older..." Command="{Binding AddFolderCommand}" InputGesture="Ctrl+Shift+O"/>
        <Separator/>
        <MenuItem Header="E_xit" Click="OnExitClick"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Open _Logs Folder" Command="{Binding OpenLogsFolderCommand}"/>
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}"/>
      </MenuItem>
    </Menu>

    <!-- 2. Main Content (Split: Playlist | Sidebar) -->
    <Grid Grid.Row="1" ColumnDefinitions="*, 4, 400">

      <!-- Playlist (Left) -->
      <DockPanel Grid.Column="0" Margin="10,10,0,10">
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
            <Button Command="{Binding AddFilesCommand}" ToolTip.Tip="Browse media files" Height="40">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6H12L10,4Z"
                              Width="24" Height="24"/>
                    <TextBlock Text="Browse" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#333" Padding="8,8" CornerRadius="4,4,0,0">
            <Grid ColumnDefinitions="*, 120, 120">
                <TextBlock Text="Name" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="Duration" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- List -->
        <ListBox Name="PlaylistList"
                 ItemsSource="{Binding Playlist}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 DragDrop.AllowDrop="True"
                 DragDrop.DragOver="Playlist_DragOver"
                 DragDrop.Drop="Playlist_Drop"
                 Background="Transparent"
                 BorderThickness="1"
                 BorderBrush="#333">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                   <Setter Property="Padding" Value="8,8"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PlaylistItemViewModel">
                    <Grid ColumnDefinitions="*, 120, 120">
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Duration}" Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Status}" Opacity="0.7" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

      <!-- Sidebar (Right) -->
      <ScrollViewer Grid.Column="2" Padding="10">
          <StackPanel Spacing="20">

              <!-- Preview Monitor -->
              <StackPanel Spacing="5">
                  <TextBlock Text="PREVIEW MONITOR" FontWeight="Bold" Opacity="0.7" FontSize="24"/>
                  <Border Background="Black" CornerRadius="4" Height="225" ClipToBounds="True">
                      <vlc:VideoView Name="PreviewVideoView"/>
                  </Border>
                  <Grid ColumnDefinitions="*, Auto">
                      <TextBlock Text="{Binding PreviewStatusText}" TextWrapping="Wrap" Opacity="0.8" VerticalAlignment="Center"/>
                      <Button Grid.Column="1" Content="Cue Next" Command="{Binding CueNextPreviewCommand}" Padding="8,4"/>
                  </Grid>
              </StackPanel>

              <Separator Opacity="0.3"/>

              <!-- Playback Controls (Speed) -->
              <StackPanel Spacing="5">
                  <TextBlock Text="PLAYBACK SPEED" FontWeight="Bold" Opacity="0.7" FontSize="24"/>
                  <Grid ColumnDefinitions="Auto, *, Auto">
                      <Button Grid.Column="0" Content="-" Command="{Binding DecreaseSpeedCommand}" Width="40" Height="40" Margin="0,0,5,0"/>
                      <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSpeeds}"
                                SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}"
                                HorizontalAlignment="Stretch"/>
                      <Button Grid.Column="2" Content="+" Command="{Binding IncreaseSpeedCommand}" Width="40" Height="40" Margin="5,0,0,0"/>
                  </Grid>
                  <TextBlock Text="Hotkeys: [ ]" HorizontalAlignment="Center" Opacity="0.5" FontSize="12"/>
              </StackPanel>

              <Separator Opacity="0.3"/>

              <!-- Panic -->
              <Border Background="#330000" CornerRadius="6" Padding="15">
                  <StackPanel Spacing="10">
                      <TextBlock Text="🚨 PANIC CONTROL" FontWeight="Bold" Foreground="#FF5555" FontSize="24" HorizontalAlignment="Center"/>
                      <Button Content="BLACKOUT (F12)"
                              Command="{Binding PanicCommand}"
                              Background="#AA0000"
                              Foreground="White"
                              HorizontalAlignment="Stretch"
                              FontSize="24"
                              FontWeight="Bold"
                              Padding="10"
                              Height="60"/>
                      <TextBlock Text="Immediately cuts output to black and pauses playback."
                                 TextWrapping="Wrap"
                                 Opacity="0.6"
                                 TextAlignment="Center"/>
                  </StackPanel>
              </Border>

          </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- 3. Transport Bar (Bottom) -->
    <Border Grid.Row="2" Background="#222" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10">
        <Grid ColumnDefinitions="Auto, *, Auto">

            <!-- Left: Status -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                 <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="18"/>
            </StackPanel>

            <!-- Center: Transport Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Button Content="Prev" Command="{Binding PlayPrevCommand}" Width="80" Height="40" ToolTip.Tip="Play Previous"/>
                <Button Content="-10s" Command="{Binding SeekBackCommand}" Width="60" Height="40" ToolTip.Tip="Shift+Left"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="80" Height="40" Background="#442222" ToolTip.Tip="S"/>
                <Button Content="Play/Pause" Command="{Binding TogglePlayPauseCommand}" Width="150" Height="40" FontWeight="Bold" Background="#224422" ToolTip.Tip="Space"/>
                <Button Content="+10s" Command="{Binding SeekForwardCommand}" Width="60" Height="40" ToolTip.Tip="Shift+Right"/>
                <Button Content="Next" Command="{Binding PlayNextCommand}" Width="80" Height="40" ToolTip.Tip="Play Next"/>
                <Button Content="Step" Command="{Binding FrameStepCommand}" Height="40" ToolTip.Tip="F"/>
            </StackPanel>

            <!-- Right: Tools -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Clear Playlist" Command="{Binding ClearPlaylistCommand}" Height="40"/>
            </StackPanel>
        </Grid>
    </Border>

  </Grid>
</Window>
