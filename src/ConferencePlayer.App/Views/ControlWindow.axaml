<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ConferencePlayer.ViewModels"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="ConferencePlayer.Views.ControlWindow"
        x:DataType="vm:ControlViewModel"
        Title="{Binding WindowTitle}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

  <Window.KeyBindings>
    <KeyBinding Gesture="Space" Command="{Binding TogglePlayPauseCommand}"/>
    <KeyBinding Gesture="Enter" Command="{Binding PlaySelectedCommand}"/>
    <KeyBinding Gesture="Delete" Command="{Binding RemoveSelectedCommand}"/>
    <KeyBinding Gesture="F" Command="{Binding FrameStepCommand}"/>
    <KeyBinding Gesture="F12" Command="{Binding PanicCommand}"/>

    <KeyBinding Gesture="Ctrl+O" Command="{Binding AddFilesCommand}"/>
    <KeyBinding Gesture="Ctrl+Shift+O" Command="{Binding AddFolderCommand}"/>

    <KeyBinding Gesture="Ctrl+Left" Command="{Binding PrevCommand}"/>
    <KeyBinding Gesture="Ctrl+Right" Command="{Binding NextCommand}"/>
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto, *, Auto">
    <!-- 1. Top Menu -->
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="Add _Files..." Command="{Binding AddFilesCommand}" InputGesture="Ctrl+O"/>
        <MenuItem Header="Add F_older..." Command="{Binding AddFolderCommand}" InputGesture="Ctrl+Shift+O"/>
        <Separator/>
        <MenuItem Header="E_xit" Click="OnExitClick"/>
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="Open _Logs Folder" Command="{Binding OpenLogsFolderCommand}"/>
      </MenuItem>
      <MenuItem Header="_Tools">
        <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}"/>
      </MenuItem>
    </Menu>

    <!-- 2. Main Content (Split: Playlist | Sidebar) -->
    <Grid Grid.Row="1" ColumnDefinitions="*, 4, 320">

      <!-- Playlist (Left) -->
      <DockPanel Grid.Column="0" Margin="10,10,0,10">
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#333" Padding="8,4" CornerRadius="4,4,0,0">
            <Grid ColumnDefinitions="*, 80, 80">
                <TextBlock Text="Name" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="Duration" FontWeight="Bold"/>
                <TextBlock Grid.Column="2" Text="Status" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- List -->
        <ListBox Name="PlaylistList"
                 ItemsSource="{Binding Playlist}"
                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                 DragDrop.AllowDrop="True"
                 DragDrop.DragOver="Playlist_DragOver"
                 DragDrop.Drop="Playlist_Drop"
                 Background="Transparent"
                 BorderThickness="1"
                 BorderBrush="#333">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                   <Setter Property="Padding" Value="8,4"/>
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:PlaylistItemViewModel">
                    <Grid ColumnDefinitions="*, 80, 80">
                        <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding Duration}" Opacity="0.7" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding Status}" Opacity="0.7" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>

      <!-- Splitter -->
      <GridSplitter Grid.Column="1" Background="Transparent" ResizeDirection="Columns"/>

      <!-- Sidebar (Right) -->
      <ScrollViewer Grid.Column="2" Padding="10">
          <StackPanel Spacing="20">

              <!-- Preview Monitor -->
              <StackPanel Spacing="5">
                  <TextBlock Text="PREVIEW MONITOR" FontWeight="Bold" Opacity="0.7" FontSize="12"/>
                  <Border Background="Black" CornerRadius="4" Height="180" ClipToBounds="True">
                      <vlc:VideoView Name="PreviewVideoView"/>
                  </Border>
                  <Grid ColumnDefinitions="*, Auto">
                      <TextBlock Text="{Binding PreviewStatusText}" TextWrapping="Wrap" Opacity="0.8" FontSize="12" VerticalAlignment="Center"/>
                      <Button Grid.Column="1" Content="Cue Next" Command="{Binding CueNextPreviewCommand}" FontSize="12" Padding="8,4"/>
                  </Grid>
              </StackPanel>

              <Separator Opacity="0.3"/>

              <!-- Playback Controls (Speed) -->
              <StackPanel Spacing="5">
                  <TextBlock Text="PLAYBACK SPEED" FontWeight="Bold" Opacity="0.7" FontSize="12"/>
                  <ComboBox ItemsSource="{Binding AvailableSpeeds}"
                            SelectedItem="{Binding SelectedSpeed, Mode=TwoWay}"
                            HorizontalAlignment="Stretch"/>
              </StackPanel>

              <Separator Opacity="0.3"/>

              <!-- Panic -->
              <Border Background="#330000" CornerRadius="6" Padding="15">
                  <StackPanel Spacing="10">
                      <TextBlock Text="🚨 PANIC CONTROL" FontWeight="Bold" Foreground="#FF5555" HorizontalAlignment="Center"/>
                      <Button Content="BLACKOUT (F12)"
                              Command="{Binding PanicCommand}"
                              Background="#AA0000"
                              Foreground="White"
                              HorizontalAlignment="Stretch"
                              FontWeight="Bold"
                              Padding="10"/>
                      <TextBlock Text="Immediately cuts output to black and pauses playback."
                                 TextWrapping="Wrap"
                                 FontSize="11"
                                 Opacity="0.6"
                                 TextAlignment="Center"/>
                  </StackPanel>
              </Border>

          </StackPanel>
      </ScrollViewer>
    </Grid>

    <!-- 3. Transport Bar (Bottom) -->
    <Border Grid.Row="2" Background="#222" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="10">
        <Grid ColumnDefinitions="Auto, *, Auto">

            <!-- Left: Status -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="15">
                 <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="14"/>
            </StackPanel>

            <!-- Center: Transport Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                <Button Content="Previous" Command="{Binding PrevCommand}" Width="80" ToolTip.Tip="Ctrl+Left"/>
                <Button Content="Stop" Command="{Binding StopCommand}" Width="80" Background="#442222"/>
                <Button Content="Play/Pause" Command="{Binding TogglePlayPauseCommand}" Width="100" FontWeight="Bold" Background="#224422" ToolTip.Tip="Space"/>
                <Button Content="Next" Command="{Binding NextCommand}" Width="80" ToolTip.Tip="Ctrl+Right"/>
                <Button Content="Step" Command="{Binding FrameStepCommand}" ToolTip.Tip="F"/>
            </StackPanel>

            <!-- Right: Tools -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Button Content="Clear Playlist" Command="{Binding ClearPlaylistCommand}"/>
            </StackPanel>
        </Grid>
    </Border>

  </Grid>
</Window>
